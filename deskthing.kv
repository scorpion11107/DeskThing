<MainScreen>:
    FloatLayout:
        pos: 0, 0
        size: root.width, root.height

        Button: # First button
            text: "Button one"
            pos_hint: {"x": 0.1,"y": 0.1}
            size_hint: 0.8, 0.1

        Button: # Second button
            text: "Button two"
            pos_hint: {"x": 0.1,"y": 0.6}
            size_hint: 0.8, 0.1